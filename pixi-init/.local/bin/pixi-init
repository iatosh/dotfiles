#!/usr/bin/env -S pixi exec --spec python=3.11 --spec pyyaml -- python
"""Interactive Pixi project generator"""

import os
import sys
import yaml
import subprocess
from pathlib import Path
from typing import Dict, List, Any, Optional

CONFIG_DIR = Path.home() / ".config" / "pixi-init"

def load_yaml(file_path: Path) -> Dict[str, Any]:
    """Load YAML configuration file"""
    with open(file_path, 'r') as f:
        return yaml.safe_load(f)

def run_gum(command: List[str]) -> str:
    """Run gum command and return output"""
    try:
        # stdinとstderrは端末を使い、stdoutのみキャプチャ
        result = subprocess.run(
            command,
            text=True,
            stdout=subprocess.PIPE,
            stdin=sys.stdin,
            stderr=sys.stderr
        )
        return result.stdout.strip()
    except FileNotFoundError:
        print("Error: 'gum' is not installed. Please install it first:")
        print("  brew install gum  # macOS")
        print("  go install github.com/charmbracelet/gum@latest  # Go")
        sys.exit(1)

class PixiProjectGenerator:
    def __init__(self):
        self.tools_config = load_yaml(CONFIG_DIR / "tools.yaml")
        self.structures_config = load_yaml(CONFIG_DIR / "structures.yaml")
        
    def generate_pixi_toml(
        self,
        project_name: str,
        python_version: str,
        project_type: str,
        selected_tools: List[str],
        pytorch_variant: str
    ) -> str:
        """Generate pixi.toml content based on configuration"""
        
        content = f"""[project]
name = "{project_name}"
channels = ["conda-forge"]
platforms = ["linux-64", "osx-arm64", "win-64"]

[dependencies]
python = "{python_version}.*"
"""
        
        # Add PyTorch variant
        if project_type == "ML":
            content += f'{pytorch_variant} = "*"\n'
        
        # Add base dependencies for project type
        structure = self.structures_config["project_types"][project_type]
        for dep in structure.get("base_dependencies", []):
            content += f"{dep}\n"
        
        # Add tool dependencies
        for tool_key, tool in self.tools_config["tools"].items():
            if tool["name"] in selected_tools or tool.get("required", False):
                for dep in tool.get("dependencies", []):
                    content += f"{dep}\n"
        
        # Add tool configurations
        for tool_key, tool in self.tools_config["tools"].items():
            if tool["name"] in selected_tools or tool.get("required", False):
                for config_name, config in tool.get("config", {}).items():
                    content += f"\n[{config['section']}]\n"
                    content += config["content"].format(python_version=python_version)
                    content += "\n"
        
        # Add tasks
        content += "\n[tasks]\n"
        all_check_tasks = []
        
        # Add tasks from tools
        for tool_key, tool in self.tools_config["tools"].items():
            if tool["name"] in selected_tools or tool.get("required", False):
                for task_name, task_cmd in tool.get("tasks", {}).items():
                    content += f'{task_name} = "{task_cmd}"\n'
                all_check_tasks.extend(tool.get("check_tasks", []))
        
        # Add project type specific tasks
        for task_name, task_cmd in structure.get("tasks", {}).items():
            content += f'{task_name} = "{task_cmd}"\n'
        
        # Add combined tasks
        if all_check_tasks:
            check_deps = ", ".join([f'"{t}"' for t in all_check_tasks])
            content += f'\ncheck = {{ depends_on = [{check_deps}] }}\n'
        
        content += 'pre-commit = { depends_on = ["format", "lint"] }\n'
        
        return content
    
    def create_project_structure(
        self,
        project_path: Path,
        project_type: str,
        selected_tools: List[str]
    ):
        """Create project directory structure based on configuration"""
        
        structure = self.structures_config["project_types"][project_type]
        
        # Create base directories
        for directory in structure.get("directories", []):
            (project_path / directory).mkdir(parents=True, exist_ok=True)
        
        # Create directories from tools
        for tool_key, tool in self.tools_config["tools"].items():
            if tool["name"] in selected_tools:
                for directory in tool.get("creates_dirs", []):
                    (project_path / directory).mkdir(parents=True, exist_ok=True)
        
        # Create base files
        for file_path, content in structure.get("files", {}).items():
            file = project_path / file_path
            file.parent.mkdir(parents=True, exist_ok=True)
            file.write_text(content)
        
        # Create files from tools
        for tool_key, tool in self.tools_config["tools"].items():
            if tool["name"] in selected_tools:
                # Skip GitHub Actions CI here - it's handled separately
                if tool["name"] == "GitHub Actions CI":
                    continue
                for file_path, content in tool.get("creates_files", {}).items():
                    file = project_path / file_path
                    file.parent.mkdir(parents=True, exist_ok=True)
                    file.write_text(content)
        
        # Handle file modifications (Hydra/WandB modifies train.py)
        if "Hydra" in selected_tools or "WandB" in selected_tools:
            train_file = project_path / "src" / "train.py"
            
            # Determine which template to use
            if "Hydra" in selected_tools and "WandB" in selected_tools:
                # Use WandB's template (it includes Hydra)
                for tool_key, tool in self.tools_config["tools"].items():
                    if tool["name"] == "WandB":
                        content = tool.get("modifies_files", {}).get("src/train.py", "")
                        if content:
                            train_file.write_text(content)
                            break
            elif "Hydra" in selected_tools:
                # Use Hydra's template
                for tool_key, tool in self.tools_config["tools"].items():
                    if tool["name"] == "Hydra":
                        content = tool.get("modifies_files", {}).get("src/train.py", "")
                        if content:
                            train_file.write_text(content)
                            break
    
    def generate_gitignore(
        self,
        project_type: str,
        selected_tools: List[str]
    ) -> str:
        """Generate .gitignore content"""
        
        # Load base gitignore from template
        gitignore_template = CONFIG_DIR / "templates" / "gitignore.txt"
        if gitignore_template.exists():
            base_gitignore = gitignore_template.read_text()
        else:
            base_gitignore = """# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Pixi
.pixi/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Logs
*.log
"""
        
        # Add project type specific ignores
        structure = self.structures_config["project_types"][project_type]
        ignores = []
        for pattern in structure.get("gitignore_additions", []):
            ignores.append(pattern)
        
        # Add tool specific ignores
        for tool_key, tool in self.tools_config["tools"].items():
            if tool["name"] in selected_tools:
                for pattern in tool.get("gitignore_additions", []):
                    ignores.append(pattern)
        
        if ignores:
            base_gitignore += "\n# Project specific\n"
            base_gitignore += "\n".join(ignores)
        
        return base_gitignore
    
    def generate_gitattributes(
        self,
        project_type: str,
        selected_tools: List[str]
    ) -> str:
        """Generate .gitattributes content"""
        
        # Load base gitattributes from template
        gitattributes_template = CONFIG_DIR / "templates" / "gitattributes.txt"
        if gitattributes_template.exists():
            base_gitattributes = gitattributes_template.read_text()
        else:
            base_gitattributes = """# SCM syntax highlighting & preventing 3-way merges
pixi.lock merge=binary linguist-language=YAML linguist-generated=true
"""
        
        # Add project type specific attributes
        structure = self.structures_config["project_types"][project_type]
        additions = []
        for line in structure.get("gitattributes_additions", []):
            additions.append(line)
        
        # Add tool specific attributes
        for tool_key, tool in self.tools_config["tools"].items():
            if tool["name"] in selected_tools:
                for line in tool.get("gitattributes_additions", []):
                    additions.append(line)
        
        if additions:
            base_gitattributes += "\n"
            base_gitattributes += "\n".join(additions)
        
        return base_gitattributes
    
    def generate_readme(self, project_name: str, selected_tools: List[str]) -> str:
        """Generate README.md content"""
        
        commands = ["pixi run train"] if "train" in str(self.tools_config) else []
        
        if "pytest" in [tool["name"] for tool in self.tools_config["tools"].values()]:
            if "pytest" in selected_tools:
                commands.append("pixi run test")
        
        if "Marimo" in selected_tools:
            commands.append("pixi run notebook")
        
        if "Jupyter" in selected_tools:
            commands.append("pixi run lab")
        
        commands_section = "\n".join([f"- `{cmd}`" for cmd in commands]) if commands else "- `pixi shell` - Enter the environment"
        
        return f"""# {project_name}

## Setup

```bash
# Install pixi if not already installed
curl -fsSL https://pixi.sh/install.sh | bash

# Install dependencies
pixi install
```

## Available Commands

{commands_section}

## Development

- `pixi run format` - Format code with Black
- `pixi run lint` - Lint code with Ruff
- `pixi run check` - Run all checks
"""

def main():
    generator = PixiProjectGenerator()
    
    print("🚀 Pixi Project Setup\n")
    
    # Get project details
    project_name = run_gum(["gum", "input", "--placeholder", "Project name"])
    if not project_name:
        project_name = "my-project"
    
    python_version = run_gum([
        "gum", "input",
        "--header", "Python version:",
        "--placeholder", "Python version",
        "--value", "3.11"
    ])
    
    # Select project type
    project_types = list(generator.structures_config["project_types"].keys())
    project_type = run_gum(["gum", "choose"] + project_types)
    
    # PyTorch variant selection for ML projects
    pytorch_variant = "pytorch-cpu"  # default
    if project_type == "ML":
        pytorch_variant = run_gum([
            "gum", "choose",
            "--header", "Select PyTorch variant:",
            "pytorch-gpu",
            "pytorch-cpu"
        ])
    
    # Select tools
    tool_names = []
    default_selected = []
    
    for tool_key, tool in generator.tools_config["tools"].items():
        tool_names.append(tool["name"])
        if tool.get("required", False):
            default_selected.append(tool["name"])
    
    # Create the gum command with proper selected items
    gum_cmd = ["gum", "choose", "--no-limit"]
    if default_selected:
        gum_cmd.extend(["--selected", ",".join(default_selected)])
    gum_cmd.extend(tool_names)
    
    tools_output = run_gum(gum_cmd)
    selected_tools = tools_output.strip().split("\n") if tools_output else default_selected
    
    # DVC configuration
    if "DVC" in selected_tools:
        storage_type = run_gum([
            "gum", "choose",
            "--header", "DVC remote storage:",
            "Google Drive",
            "AWS S3",
            "Local/NAS path",
            "Skip (configure later)"
        ])
        
        if storage_type != "Skip (configure later)":
            # Create .dvc/config based on selection
            # This will be handled in the create_project_structure method
            pass
    
    # Git setup
    init_git = run_gum(["gum", "confirm", "Initialize Git repository?"]) == ""
    
    setup_ci = False
    if init_git:
        setup_ci = run_gum(["gum", "confirm", "Setup GitHub Actions CI?"]) == ""
    
    # Create project
    project_path = Path(project_name)
    project_path.mkdir(exist_ok=True)
    
    print(f"\n📁 Creating project: {project_name}")
    
    # Generate files
    pixi_toml = generator.generate_pixi_toml(
        project_name, python_version, project_type, selected_tools, pytorch_variant
    )
    (project_path / "pixi.toml").write_text(pixi_toml)
    
    # Create .gitignore
    gitignore = generator.generate_gitignore(project_type, selected_tools)
    (project_path / ".gitignore").write_text(gitignore)
    
    # Create .gitattributes
    gitattributes = generator.generate_gitattributes(project_type, selected_tools)
    (project_path / ".gitattributes").write_text(gitattributes)
    
    # Create README
    readme = generator.generate_readme(project_name, selected_tools)
    (project_path / "README.md").write_text(readme)
    
    # Create project structure
    if project_type != "Custom":
        generator.create_project_structure(project_path, project_type, selected_tools)
    
    # Handle CI setup
    if setup_ci:
        ci_path = project_path / ".github" / "workflows"
        ci_path.mkdir(parents=True, exist_ok=True)
        
        # Find GitHub Actions configuration
        for tool_key, tool in generator.tools_config["tools"].items():
            if tool["name"] == "GitHub Actions CI":
                for file_path, content in tool.get("creates_files", {}).items():
                    # Customize CI based on selected tools
                    additional_steps = ""
                    if "pytest" in selected_tools:
                        additional_steps += """
            - name: Run tests
              run: pixi run test
"""
                    if "mypy" in selected_tools:
                        additional_steps += """
            - name: Type check
              run: pixi run typecheck
              continue-on-error: true
"""
                    
                    content = content.replace("{additional_steps}", additional_steps)
                    (project_path / file_path).write_text(content)
    
    # Initialize git if requested
    if init_git:
        os.chdir(project_path)
        subprocess.run(["git", "init"], capture_output=True)
        subprocess.run(["git", "add", "."], capture_output=True)
        subprocess.run(["git", "commit", "-m", "Initial commit"], capture_output=True)
        os.chdir("..")
    
    print(f"✅ Project created successfully!")
    print(f"\nNext steps:")
    print(f"  cd {project_name}")
    print(f"  pixi install")
    if project_type == "ML":
        print(f"  pixi run train")

if __name__ == "__main__":
    main()
