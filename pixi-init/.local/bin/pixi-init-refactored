#!/usr/bin/env -S pixi exec --spec python=3.11 --spec pyyaml --spec typing-extensions -- python
"""Interactive Pixi project generator - Refactored Version"""

import os
import sys
import yaml
import subprocess
from abc import ABC, abstractmethod
from dataclasses import dataclass, field
from enum import Enum
from pathlib import Path
from typing import Dict, List, Any, Optional, Protocol, Set

# Constants
CONFIG_DIR = Path.home() / ".config" / "pixi-init"
DEFAULT_PYTHON_VERSION = "3.11"
DEFAULT_PROJECT_NAME = "my-project"

# Data Models
@dataclass
class Tool:
    """Represents a development tool configuration"""
    name: str
    dependencies: List[str] = field(default_factory=list)
    tasks: Dict[str, str] = field(default_factory=dict)
    config: Dict[str, Dict[str, Any]] = field(default_factory=dict)
    creates_dirs: List[str] = field(default_factory=list)
    creates_files: Dict[str, str] = field(default_factory=dict)
    modifies_files: Dict[str, str] = field(default_factory=dict)
    gitignore_additions: List[str] = field(default_factory=list)
    gitattributes_additions: List[str] = field(default_factory=list)
    check_tasks: List[str] = field(default_factory=list)
    required: bool = False

@dataclass
class ProjectStructure:
    """Represents a project type structure"""
    name: str
    base_dependencies: List[str] = field(default_factory=list)
    directories: List[str] = field(default_factory=list)
    files: Dict[str, str] = field(default_factory=dict)
    tasks: Dict[str, str] = field(default_factory=dict)
    gitignore_additions: List[str] = field(default_factory=list)
    gitattributes_additions: List[str] = field(default_factory=list)

@dataclass
class ProjectConfig:
    """Configuration for a new project"""
    name: str
    python_version: str
    project_type: str
    selected_tools: List[str]
    pytorch_variant: Optional[str] = None
    init_git: bool = False
    setup_ci: bool = False

class StorageType(Enum):
    """DVC storage type options"""
    GOOGLE_DRIVE = "Google Drive"
    AWS_S3 = "AWS S3"
    LOCAL_NAS = "Local/NAS path"
    SKIP = "Skip (configure later)"

# Exceptions
class PixiInitError(Exception):
    """Base exception for pixi-init errors"""
    pass

class ConfigError(PixiInitError):
    """Configuration related errors"""
    pass

class GumError(PixiInitError):
    """Gum command related errors"""
    pass

# Interfaces
class FileGenerator(Protocol):
    """Protocol for file generators"""
    def generate(self, config: ProjectConfig, tools: Dict[str, Tool], 
                structures: Dict[str, ProjectStructure]) -> str:
        ...

# Utility Functions
def load_yaml(file_path: Path) -> Dict[str, Any]:
    """Load YAML configuration file with error handling"""
    try:
        with open(file_path, 'r') as f:
            return yaml.safe_load(f)
    except FileNotFoundError:
        raise ConfigError(f"Configuration file not found: {file_path}")
    except yaml.YAMLError as e:
        raise ConfigError(f"Invalid YAML in {file_path}: {e}")

def run_gum(command: List[str]) -> str:
    """Run gum command with improved error handling"""
    try:
        result = subprocess.run(
            command,
            text=True,
            stdout=subprocess.PIPE,
            stdin=sys.stdin,
            stderr=sys.stderr,
            check=False
        )
        if result.returncode != 0 and "confirm" not in command:
            raise GumError(f"Gum command failed: {' '.join(command)}")
        return result.stdout.strip()
    except FileNotFoundError:
        raise GumError(
            "Error: 'gum' is not installed. Please install it first:\n"
            "  brew install gum  # macOS\n"
            "  go install github.com/charmbracelet/gum@latest  # Go"
        )

# File Generators
class PixiTomlGenerator:
    """Generates pixi.toml content"""
    
    def generate(self, config: ProjectConfig, tools: Dict[str, Tool], 
                structures: Dict[str, ProjectStructure]) -> str:
        structure = structures.get(config.project_type)
        if not structure:
            raise ConfigError(f"Unknown project type: {config.project_type}")
        
        sections = [
            self._generate_project_section(config),
            self._generate_dependencies_section(config, tools, structure),
            self._generate_config_sections(config, tools),
            self._generate_tasks_section(config, tools, structure)
        ]
        
        return "\n".join(filter(None, sections))
    
    def _generate_project_section(self, config: ProjectConfig) -> str:
        return f"""[project]
name = "{config.name}"
channels = ["conda-forge"]
platforms = ["linux-64", "osx-arm64", "win-64"]"""
    
    def _generate_dependencies_section(self, config: ProjectConfig, 
                                     tools: Dict[str, Tool], 
                                     structure: ProjectStructure) -> str:
        deps = [f'python = "{config.python_version}.*"']
        
        if config.project_type == "ML" and config.pytorch_variant:
            deps.append(f'{config.pytorch_variant} = "*"')
        
        deps.extend(f"{dep}" for dep in structure.base_dependencies)
        
        for tool in tools.values():
            if tool.name in config.selected_tools or tool.required:
                deps.extend(f"{dep}" for dep in tool.dependencies)
        
        return "[dependencies]\n" + "\n".join(deps)
    
    def _generate_config_sections(self, config: ProjectConfig, 
                                tools: Dict[str, Tool]) -> str:
        sections = []
        for tool in tools.values():
            if tool.name in config.selected_tools or tool.required:
                for cfg_name, cfg in tool.config.items():
                    section = f"\n[{cfg['section']}]\n"
                    content = cfg["content"].format(
                        python_version=config.python_version
                    )
                    sections.append(section + content)
        return "\n".join(sections)
    
    def _generate_tasks_section(self, config: ProjectConfig, 
                              tools: Dict[str, Tool], 
                              structure: ProjectStructure) -> str:
        tasks = {}
        check_tasks = []
        
        for tool in tools.values():
            if tool.name in config.selected_tools or tool.required:
                tasks.update(tool.tasks)
                check_tasks.extend(tool.check_tasks)
        
        tasks.update(structure.tasks)
        
        task_lines = ["\n[tasks]"]
        task_lines.extend(f'{name} = "{cmd}"' for name, cmd in tasks.items())
        
        if check_tasks:
            deps = ", ".join(f'"{t}"' for t in check_tasks)
            task_lines.append(f'check = {{ depends_on = [{deps}] }}')
        
        task_lines.append('pre-commit = { depends_on = ["format", "lint"] }')
        
        return "\n".join(task_lines)

class GitIgnoreGenerator:
    """Generates .gitignore content"""
    
    BASE_TEMPLATE = """# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Pixi
.pixi/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Logs
*.log
"""
    
    def generate(self, config: ProjectConfig, tools: Dict[str, Tool], 
                structures: Dict[str, ProjectStructure]) -> str:
        template_path = CONFIG_DIR / "templates" / "gitignore.txt"
        base_content = (
            template_path.read_text() if template_path.exists() 
            else self.BASE_TEMPLATE
        )
        
        structure = structures.get(config.project_type, ProjectStructure(name=""))
        ignores = list(structure.gitignore_additions)
        
        for tool in tools.values():
            if tool.name in config.selected_tools:
                ignores.extend(tool.gitignore_additions)
        
        if ignores:
            base_content += "\n# Project specific\n"
            base_content += "\n".join(set(ignores))  # Remove duplicates
        
        return base_content

class ReadmeGenerator:
    """Generates README.md content"""
    
    def generate(self, config: ProjectConfig, tools: Dict[str, Tool], 
                structures: Dict[str, ProjectStructure]) -> str:
        commands = self._get_available_commands(config, tools, structures)
        commands_section = (
            "\n".join(f"- `{cmd}`" for cmd in commands) 
            if commands else "- `pixi shell` - Enter the environment"
        )
        
        return f"""# {config.name}

## Setup

```bash
# Install pixi if not already installed
curl -fsSL https://pixi.sh/install.sh | bash

# Install dependencies
pixi install
```

## Available Commands

{commands_section}

## Development

- `pixi run format` - Format code with Black
- `pixi run lint` - Lint code with Ruff
- `pixi run check` - Run all checks
"""
    
    def _get_available_commands(self, config: ProjectConfig, 
                               tools: Dict[str, Tool], 
                               structures: Dict[str, ProjectStructure]) -> List[str]:
        commands = []
        structure = structures.get(config.project_type, ProjectStructure(name=""))
        
        if "train" in structure.tasks:
            commands.append("pixi run train")
        
        tool_commands = {
            "pytest": "pixi run test",
            "Marimo": "pixi run notebook",
            "Jupyter": "pixi run lab"
        }
        
        for tool_name, cmd in tool_commands.items():
            if tool_name in config.selected_tools:
                commands.append(cmd)
        
        return commands

# Main Application Classes
class ProjectBuilder:
    """Handles project structure creation"""
    
    def build(self, project_path: Path, config: ProjectConfig, 
             tools: Dict[str, Tool], structures: Dict[str, ProjectStructure]):
        """Build the project structure"""
        structure = structures.get(config.project_type)
        if not structure:
            raise ConfigError(f"Unknown project type: {config.project_type}")
        
        self._create_directories(project_path, config, tools, structure)
        self._create_files(project_path, config, tools, structure)
        self._handle_file_modifications(project_path, config, tools)
    
    def _create_directories(self, project_path: Path, config: ProjectConfig,
                          tools: Dict[str, Tool], structure: ProjectStructure):
        """Create all required directories"""
        dirs_to_create = set(structure.directories)
        
        for tool in tools.values():
            if tool.name in config.selected_tools:
                dirs_to_create.update(tool.creates_dirs)
        
        for directory in dirs_to_create:
            (project_path / directory).mkdir(parents=True, exist_ok=True)
    
    def _create_files(self, project_path: Path, config: ProjectConfig,
                     tools: Dict[str, Tool], structure: ProjectStructure):
        """Create all required files"""
        files_to_create = dict(structure.files)
        
        for tool in tools.values():
            if tool.name in config.selected_tools:
                # Skip GitHub Actions CI here - it's handled separately
                if tool.name == "GitHub Actions CI":
                    continue
                files_to_create.update(tool.creates_files)
        
        for file_path, content in files_to_create.items():
            file = project_path / file_path
            file.parent.mkdir(parents=True, exist_ok=True)
            file.write_text(content)
    
    def _handle_file_modifications(self, project_path: Path, 
                                 config: ProjectConfig, tools: Dict[str, Tool]):
        """Handle special file modifications (e.g., Hydra/WandB)"""
        if not any(tool in config.selected_tools for tool in ["Hydra", "WandB"]):
            return
        
        train_file = project_path / "src" / "train.py"
        
        # Prioritize WandB template if both are selected
        if "WandB" in config.selected_tools:
            tool_name = "WandB"
        elif "Hydra" in config.selected_tools:
            tool_name = "Hydra"
        else:
            return
        
        for tool in tools.values():
            if tool.name == tool_name:
                content = tool.modifies_files.get("src/train.py", "")
                if content:
                    train_file.write_text(content)
                break

class UserInterface:
    """Handles user interactions"""
    
    def get_project_config(self, structures: Dict[str, ProjectStructure],
                          tools: Dict[str, Tool]) -> ProjectConfig:
        """Get project configuration from user"""
        print("🚀 Pixi Project Setup\n")
        
        name = self._get_project_name()
        python_version = self._get_python_version()
        project_type = self._get_project_type(list(structures.keys()))
        pytorch_variant = self._get_pytorch_variant(project_type)
        selected_tools = self._get_selected_tools(tools)
        init_git = self._confirm("Initialize Git repository?")
        setup_ci = init_git and self._confirm("Setup GitHub Actions CI?")
        
        return ProjectConfig(
            name=name,
            python_version=python_version,
            project_type=project_type,
            selected_tools=selected_tools,
            pytorch_variant=pytorch_variant,
            init_git=init_git,
            setup_ci=setup_ci
        )
    
    def _get_project_name(self) -> str:
        name = run_gum(["gum", "input", "--placeholder", "Project name"])
        return name if name else DEFAULT_PROJECT_NAME
    
    def _get_python_version(self) -> str:
        return run_gum([
            "gum", "input",
            "--header", "Python version:",
            "--placeholder", "Python version",
            "--value", DEFAULT_PYTHON_VERSION
        ])
    
    def _get_project_type(self, types: List[str]) -> str:
        return run_gum(["gum", "choose"] + types)
    
    def _get_pytorch_variant(self, project_type: str) -> Optional[str]:
        if project_type != "ML":
            return None
        
        return run_gum([
            "gum", "choose",
            "--header", "Select PyTorch variant:",
            "pytorch-gpu",
            "pytorch-cpu"
        ])
    
    def _get_selected_tools(self, tools: Dict[str, Tool]) -> List[str]:
        tool_names = []
        default_selected = []
        
        for tool in tools.values():
            tool_names.append(tool.name)
            if tool.required:
                default_selected.append(tool.name)
        
        gum_cmd = ["gum", "choose", "--no-limit"]
        if default_selected:
            gum_cmd.extend(["--selected", ",".join(default_selected)])
        gum_cmd.extend(tool_names)
        
        output = run_gum(gum_cmd)
        return output.strip().split("\n") if output else default_selected
    
    def _confirm(self, message: str) -> bool:
        return run_gum(["gum", "confirm", message]) == ""

class ConfigLoader:
    """Loads and parses configuration files"""
    
    @staticmethod
    def load_tools(config_dir: Path) -> Dict[str, Tool]:
        """Load tools configuration"""
        tools_data = load_yaml(config_dir / "tools.yaml")
        tools = {}
        
        for key, data in tools_data.get("tools", {}).items():
            tool = Tool(
                name=data.get("name", key),
                dependencies=data.get("dependencies", []),
                tasks=data.get("tasks", {}),
                config=data.get("config", {}),
                creates_dirs=data.get("creates_dirs", []),
                creates_files=data.get("creates_files", {}),
                modifies_files=data.get("modifies_files", {}),
                gitignore_additions=data.get("gitignore_additions", []),
                gitattributes_additions=data.get("gitattributes_additions", []),
                check_tasks=data.get("check_tasks", []),
                required=data.get("required", False)
            )
            tools[key] = tool
        
        return tools
    
    @staticmethod
    def load_structures(config_dir: Path) -> Dict[str, ProjectStructure]:
        """Load project structures configuration"""
        structures_data = load_yaml(config_dir / "structures.yaml")
        structures = {}
        
        for key, data in structures_data.get("project_types", {}).items():
            structure = ProjectStructure(
                name=key,
                base_dependencies=data.get("base_dependencies", []),
                directories=data.get("directories", []),
                files=data.get("files", {}),
                tasks=data.get("tasks", {}),
                gitignore_additions=data.get("gitignore_additions", []),
                gitattributes_additions=data.get("gitattributes_additions", [])
            )
            structures[key] = structure
        
        return structures

class PixiInitApp:
    """Main application class"""
    
    def __init__(self):
        self.config_loader = ConfigLoader()
        self.ui = UserInterface()
        self.project_builder = ProjectBuilder()
        self.generators = {
            "pixi.toml": PixiTomlGenerator(),
            ".gitignore": GitIgnoreGenerator(),
            "README.md": ReadmeGenerator()
        }
    
    def run(self):
        """Run the application"""
        try:
            # Load configuration
            tools = self.config_loader.load_tools(CONFIG_DIR)
            structures = self.config_loader.load_structures(CONFIG_DIR)
            
            # Get user input
            config = self.ui.get_project_config(structures, tools)
            
            # Create project
            self._create_project(config, tools, structures)
            
            # Show success message
            self._show_success_message(config)
            
        except PixiInitError as e:
            print(f"\n❌ Error: {e}", file=sys.stderr)
            sys.exit(1)
        except KeyboardInterrupt:
            print("\n\n👋 Project creation cancelled.")
            sys.exit(0)
        except Exception as e:
            print(f"\n❌ Unexpected error: {e}", file=sys.stderr)
            sys.exit(1)
    
    def _create_project(self, config: ProjectConfig, tools: Dict[str, Tool],
                       structures: Dict[str, ProjectStructure]):
        """Create the project with all files and structure"""
        project_path = Path(config.name)
        project_path.mkdir(exist_ok=True)
        
        print(f"\n📁 Creating project: {config.name}")
        
        # Generate standard files
        for filename, generator in self.generators.items():
            content = generator.generate(config, tools, structures)
            (project_path / filename).write_text(content)
        
        # Create .gitattributes separately
        gitattributes = self._generate_gitattributes(config, tools, structures)
        (project_path / ".gitattributes").write_text(gitattributes)
        
        # Create project structure
        if config.project_type != "Custom":
            self.project_builder.build(project_path, config, tools, structures)
        
        # Handle CI setup
        if config.setup_ci:
            self._setup_ci(project_path, config, tools)
        
        # Initialize git
        if config.init_git:
            self._init_git(project_path)
    
    def _generate_gitattributes(self, config: ProjectConfig, 
                               tools: Dict[str, Tool],
                               structures: Dict[str, ProjectStructure]) -> str:
        """Generate .gitattributes content"""
        template_path = CONFIG_DIR / "templates" / "gitattributes.txt"
        base = (
            template_path.read_text() if template_path.exists()
            else "# SCM syntax highlighting & preventing 3-way merges\n"
                 "pixi.lock merge=binary linguist-language=YAML linguist-generated=true\n"
        )
        
        structure = structures.get(config.project_type, ProjectStructure(name=""))
        additions = list(structure.gitattributes_additions)
        
        for tool in tools.values():
            if tool.name in config.selected_tools:
                additions.extend(tool.gitattributes_additions)
        
        if additions:
            base += "\n" + "\n".join(set(additions))
        
        return base
    
    def _setup_ci(self, project_path: Path, config: ProjectConfig,
                 tools: Dict[str, Tool]):
        """Setup GitHub Actions CI"""
        ci_path = project_path / ".github" / "workflows"
        ci_path.mkdir(parents=True, exist_ok=True)
        
        for tool in tools.values():
            if tool.name == "GitHub Actions CI":
                for file_path, content in tool.creates_files.items():
                    additional_steps = self._get_ci_steps(config.selected_tools)
                    content = content.replace("{additional_steps}", additional_steps)
                    (project_path / file_path).write_text(content)
    
    def _get_ci_steps(self, selected_tools: List[str]) -> str:
        """Get additional CI steps based on selected tools"""
        steps = []
        
        if "pytest" in selected_tools:
            steps.append("""
            - name: Run tests
              run: pixi run test""")
        
        if "mypy" in selected_tools:
            steps.append("""
            - name: Type check
              run: pixi run typecheck
              continue-on-error: true""")
        
        return "\n".join(steps)
    
    def _init_git(self, project_path: Path):
        """Initialize git repository"""
        os.chdir(project_path)
        subprocess.run(["git", "init"], capture_output=True)
        subprocess.run(["git", "add", "."], capture_output=True)
        subprocess.run(["git", "commit", "-m", "Initial commit"], capture_output=True)
        os.chdir("..")
    
    def _show_success_message(self, config: ProjectConfig):
        """Show success message with next steps"""
        print(f"✅ Project created successfully!")
        print(f"\nNext steps:")
        print(f"  cd {config.name}")
        print(f"  pixi install")
        
        if config.project_type == "ML":
            print(f"  pixi run train")

def main():
    """Main entry point"""
    app = PixiInitApp()
    app.run()

if __name__ == "__main__":
    main()