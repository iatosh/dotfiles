[
  {
    "label": "Code Runner: Run File",
    "command": "if [ ${ZED_LANGUAGE} = \"Python\" ]; then uv run \"$ZED_FILE\"; elif [ ${ZED_LANGUAGE} = \"C\" ]; then mkdir -p \"${ZED_DIRNAME}/out\" && gcc \"$ZED_FILE\" -o \"${ZED_DIRNAME}/out/${ZED_STEM}\" && \"${ZED_DIRNAME}/out/${ZED_STEM}\"; elif [ ${ZED_LANGUAGE} = \"Matlab\" ]; then matlab -batch \"run('$ZED_FILE'); exit;\"; else echo \"Unsupported language extension: .$ext\"; fi",
    "show_summary": false,
    "show_command": false,
  },
]
