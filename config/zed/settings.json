{
  "proxy": "",
  "languages": {
    "Typst": {
      "inlay_hints": {
        "enabled": true,
      },
    },
  },
  "soft_wrap": "editor_width",
  "relative_line_numbers": "enabled",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "buffer_font_family": "UDEV Gothic 35NFLG",
  "terminal": {
    "font_family": "UDEV Gothic 35NFLG",
    // "font_fallbacks": ["Yutapon coding Demi Bold Sl", "UDEV Gothic 35NFLG"],
    "font_size": 14.0,
  },
  "ssh_connections": [
    {
      "host": "kodama",
      "args": [],
      "projects": [
        {
          "paths": ["/home/atosh"],
        },
        {
          "paths": ["/home/atosh/Projects"],
        },
        {
          "paths": ["/home/atosh/Projects/./"],
        },
        {
          "paths": ["/home/atosh/Projects/M1"],
        },
        {
          "paths": ["/home/atosh/Projects/Q-SingLEM"],
        },
        {
          "paths": ["/home/atosh/Projects/research-plan"],
        },
      ],
    },
    {
      "host": "kodama",
      "args": [],
      "projects": [
        {
          "paths": ["/mnt/nas/DownstreamDatasets/Seizure_Detection"],
        },
      ],
    },
  ],
  "agent_buffer_font_size": 14.0,
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "model": "sonnet",
        "mode": "auto",
      },
      "type": "registry",
    },
    "hermes-agent": {
      "type": "custom",
      "command": "hermes",
      "args": ["acp"],
    },
  },
  "agent": {
    "dock": "right",
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.2",
      "enable_thinking": false,
    },
    "default_model": {
      "provider": "Kodama",
      "model": "qwen3.6-35b",
      "enable_thinking": false,
    },
    "favorite_models": [
      {
        "provider": "GLM",
        "model": "glm-5.1",
        "enable_thinking": false,
      },
      {
        "provider": "Z.ai Coding",
        "model": "glm-5.1",
        "enable_thinking": false,
      },
      {
        "provider": "Z.ai Coding",
        "model": "glm-5-turbo",
        "enable_thinking": false,
      },
    ],
    "model_parameters": [],
  },
  "language_models": {
    "anthropic_compatible": {
      "Kodama": {
        "api_url": "https://kodama:4000",
        "available_models": [
          {
            "name": "qwen3.6-27b",
            "max_tokens": 262144,
            "max_output_tokens": 32000,
            "capabilities": {
              "tools": true,
              "images": true,
              "prompt_caching": false,
