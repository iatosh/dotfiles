  "icon_theme": {
    "mode": "dark",
    "light": "Base Charmed Icons",
    "dark": "Base Charmed Icons",
  },
  "which_key": {
    "enabled": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "edit_predictions": {
    "mode": "subtle",
    "provider": "copilot",
    "open_ai_compatible_api": {
      "model": "qwen3.6-27b",
      "api_url": "http://kodama:4000",
      "max_output_tokens": 64,
      "prompt_format": "qwen",
    },
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "base_keymap": "Cursor",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Zedokai Darker",
  },
  // Other settings
  "lsp": {
    "tinymist": {
      "settings": {
        "exportPdf": "onSave",
        "outputPath": "$root/$dir/$name",
      },
    },
    "matlab-language-server": {
      "settings": {
        "installPath": "/usr/local/MATLAB/R2024a",
        "indexWorkspace": true,
        "matlabConnectionTiming": "onStart",
        "telemetry": false,
      },
    },
  },
